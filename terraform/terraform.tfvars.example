# ──────────────────────────────────────────────
# Copy to terraform.tfvars and fill in values
# ──────────────────────────────────────────────

project_id     = "my-gcp-project-id"
region         = "us-central1"
app_name       = "tf-generator"

# Docker images (update after pushing to Artifact Registry)
backend_image  = "us-central1-docker.pkg.dev/my-gcp-project-id/tf-generator/backend:latest"
frontend_image = "us-central1-docker.pkg.dev/my-gcp-project-id/tf-generator/frontend:latest"

# OpenAI
openai_api_key = "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
openai_model   = "gpt-4o"

# Application
cors_origins   = "https://tf-generator-frontend-xxxxx.run.app"
log_level      = "info"
min_instances  = 0
max_instances  = 10
